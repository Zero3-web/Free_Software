---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs';
import NewsletterSignup from '../../components/NewsletterSignup';

const article = {
  title: "Herramientas Gratuitas de Desarrollo Web: Construye Sitios Profesionales Sin Costo",
  description: "Descubre las mejores herramientas gratuitas para desarrollo web, desde editores de código hasta frameworks, que te permitirán crear sitios web profesionales.",
  author: "Ana García",
  publishDate: "2024-12-20",
  readTime: "10 min",
  category: "Desarrollo Web",
  tags: ["Desarrollo", "Web", "Herramientas", "Gratis", "Programación", "Frontend"],
  image: "https://images.unsplash.com/photo-1461749280684-dccba630e2f6?w=1200&h=630&fit=crop&auto=format"
};

const relatedArticles = [
  {
    title: "Alternativas Gratuitas a Adobe Creative Suite",
    href: "/blog/alternativas-gratuitas-adobe-creative-suite",
    description: "Descubre potentes herramientas gratuitas para diseño gráfico, edición de video y más."
  },
  {
    title: "Las Mejores Alternativas Gratuitas a Microsoft Office",
    href: "/blog/mejores-alternativas-microsoft-office",
    description: "Explora las mejores suites ofimáticas gratuitas para reemplazar Microsoft Office."
  }
];
---

<Layout title={`${article.title} | Software Gratis`} description={article.description}>
  
  <Header />
  
  <!-- Breadcrumbs -->
  <Breadcrumbs 
    items={[
      { label: 'Inicio', href: '/' },
      { label: 'Blog', href: '/blog' },
      { label: article.title }
    ]}
    className="container-wide py-4"
    client:load
  />
  
  <main id="main-content">
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-purple-50 via-white to-blue-50 dark:from-gray-900 dark:via-gray-900 dark:to-gray-800 py-20">
      <div class="container-wide">
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-8">
            <span class="inline-block px-3 py-1 bg-purple-100 dark:bg-purple-900/30 text-purple-800 dark:text-purple-300 rounded-full text-sm font-medium mb-4">
              {article.category}
            </span>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 dark:text-white mb-6 leading-tight">
              {article.title}
            </h1>
            <p class="text-xl text-gray-600 dark:text-gray-300 mb-8 leading-relaxed">
              {article.description}
            </p>
            
            <!-- Article Meta -->
            <div class="flex flex-wrap items-center justify-center gap-6 text-sm text-gray-500 dark:text-gray-400">
              <div class="flex items-center space-x-2">
                <div class="w-8 h-8 bg-gradient-to-br from-purple-400 to-blue-500 rounded-full flex items-center justify-center">
                  <span class="text-white text-xs font-bold">{article.author.split(' ').map(n => n[0]).join('')}</span>
                </div>
                <span>Por {article.author}</span>
              </div>
              <div class="flex items-center space-x-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
                <span>{new Date(article.publishDate).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
              </div>
              <div class="flex items-center space-x-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span>{article.readTime} de lectura</span>
              </div>
            </div>
          </div>
          
          <!-- Featured Image -->
          <div class="rounded-2xl overflow-hidden shadow-2xl mb-12">
            <img 
              src={article.image} 
              alt={article.title}
              class="w-full h-96 object-cover"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Article Content -->
    <article class="py-16" itemscope itemtype="https://schema.org/BlogPosting">
      <!-- Schema.org microdata -->
      <meta itemprop="headline" content={article.title} />
      <meta itemprop="description" content={article.description} />
      <meta itemprop="author" content={article.author} />
      <meta itemprop="datePublished" content={article.publishDate} />
      <meta itemprop="image" content={article.image} />
      
      <div class="container-wide">
        <div class="max-w-4xl mx-auto">
          <div class="prose prose-lg dark:prose-invert max-w-none">
            
            <h2>¿Por qué usar herramientas gratuitas para desarrollo web?</h2>
            
            <p>El desarrollo web moderno requiere de una variedad de herramientas especializadas, desde editores de código hasta frameworks y bibliotecas. Lo increíble del ecosistema actual es que muchas de las mejores herramientas son completamente gratuitas y de código abierto.</p>
            
            <p>Usar herramientas gratuitas no significa comprometer la calidad. De hecho, muchas de estas herramientas son utilizadas por las empresas más grandes del mundo y ofrecen:</p>
            
            <ul>
              <li><strong>Actualizaciones constantes</strong>: Desarrolladas por comunidades activas</li>
              <li><strong>Extensibilidad</strong>: Plugins y extensiones para personalizar tu flujo de trabajo</li>
              <li><strong>Soporte comunitario</strong>: Documentación extensa y foros de ayuda</li>
              <li><strong>Sin restricciones</strong>: Libertad total para usar en proyectos personales y comerciales</li>
            </ul>

            <h2>Editores de código y IDEs</h2>
            
            <h3>Visual Studio Code</h3>
            
            <p>Visual Studio Code de Microsoft es probablemente el editor de código más popular entre desarrolladores web. Es gratuito, rápido y cuenta con un ecosistema masivo de extensiones.</p>
            
            <p><strong>Características destacadas:</strong></p>
            <ul>
              <li>Intellisense avanzado para múltiples lenguajes</li>
              <li>Debugging integrado</li>
              <li>Control de versiones Git integrado</li>
              <li>Terminal integrada</li>
              <li>Miles de extensiones disponibles</li>
            </ul>
            
            <h3>Atom</h3>
            
            <p>Desarrollado por GitHub, Atom es un editor "hackeable" que permite personalizaciones profundas. Aunque su desarrollo se ha ralentizado, sigue siendo una opción sólida.</p>
            
            <h3>Sublime Text</h3>
            
            <p>Aunque técnicamente es de pago, Sublime Text puede usarse indefinidamente de forma gratuita con recordatorios ocasionales para comprar la licencia. Es extremadamente rápido y eficiente.</p>

            <h2>Frameworks y bibliotecas frontend</h2>
            
            <h3>React</h3>
            
            <p>React de Facebook ha revolucionado el desarrollo frontend. Es completamente gratuito y permite crear interfaces de usuario dinámicas y eficientes.</p>
            
            <p><strong>Ventajas de React:</strong></p>
            <ul>
              <li>Virtual DOM para rendimiento optimizado</li>
              <li>Componentes reutilizables</li>
              <li>Ecosistema extenso</li>
              <li>Gran demanda laboral</li>
            </ul>
            
            <h3>Vue.js</h3>
            
            <p>Vue.js es conocido por su curva de aprendizaje suave y su flexibilidad. Es perfecto para proyectos de cualquier tamaño.</p>
            
            <h3>Svelte</h3>
            
            <p>Svelte es un framework innovador que compila el código durante el build, resultando en aplicaciones más rápidas y ligeras.</p>

            <h2>Herramientas de construcción y empaquetado</h2>
            
            <h3>Vite</h3>
            
            <p>Vite ha ganado popularidad rápidamente gracias a su velocidad de desarrollo. Utiliza ES modules nativos para hot reloading casi instantáneo.</p>
            
            <h3>Webpack</h3>
            
            <p>Webpack sigue siendo el bundler más completo y configurable, ideal para proyectos complejos que requieren configuraciones específicas.</p>
            
            <h3>Parcel</h3>
            
            <p>Parcel se destaca por su configuración cero. Es perfecto para proyectos que necesitan empezar rápidamente sin configuraciones complejas.</p>

            <h2>Control de versiones</h2>
            
            <h3>Git</h3>
            
            <p>Git es esencial para cualquier desarrollador. Es el sistema de control de versiones más utilizado en la industria.</p>
            
            <h3>GitHub</h3>
            
            <p>GitHub ofrece repositorios privados ilimitados gratis para proyectos pequeños, además de ser la plataforma de código abierto más grande del mundo.</p>
            
            <h3>GitLab</h3>
            
            <p>GitLab ofrece una plataforma completa de DevOps con repositorios gratuitos, CI/CD integrado y más funciones.</p>

            <h2>Herramientas de diseño y prototipado</h2>
            
            <h3>Figma</h3>
            
            <p>Figma revolucionó el diseño colaborativo. Su plan gratuito permite hasta 3 proyectos y es perfecto para equipos pequeños.</p>
            
            <h3>Canva</h3>
            
            <p>Aunque principalmente es una herramienta de diseño gráfico, Canva también ofrece templates para wireframes y prototipos básicos.</p>
            
            <h3>Adobe XD</h3>
            
            <p>Adobe XD tiene un plan gratuito que incluye prototipado básico y es excelente para crear interfaces de usuario.</p>

            <h2>Testing y debugging</h2>
            
            <h3>Chrome DevTools</h3>
            
            <p>Las herramientas de desarrollador de Chrome son indispensables para debugging frontend. Incluyen profiling de performance, network monitoring y mucho más.</p>
            
            <h3>Jest</h3>
            
            <p>Jest de Facebook es el framework de testing más popular para JavaScript. Incluye mocking, coverage reports y más.</p>
            
            <h3>Cypress</h3>
            
            <p>Cypress facilita el testing end-to-end con una interfaz gráfica intuitiva y debugging en tiempo real.</p>

            <h2>Hosting y deployment</h2>
            
            <h3>Netlify</h3>
            
            <p>Netlify ofrece hosting gratuito para sitios estáticos con deploy automático desde Git. Incluye formularios, functions y más.</p>
            
            <h3>Vercel</h3>
            
            <p>Vercel (anteriormente Zeit Now) es perfecto para aplicaciones Next.js y otros frameworks modernos. Deployment con un comando.</p>
            
            <h3>GitHub Pages</h3>
            
            <p>GitHub Pages permite hospedar sitios estáticos directamente desde repositorios de GitHub, perfecto para portfolios y documentación.</p>

            <h2>APIs y backend como servicio</h2>
            
            <h3>Firebase</h3>
            
            <p>Firebase de Google ofrece un plan gratuito generoso que incluye base de datos en tiempo real, autenticación y hosting.</p>
            
            <h3>Supabase</h3>
            
            <p>Supabase es una alternativa open source a Firebase que ofrece PostgreSQL como servicio con un plan gratuito robusto.</p>

            <h2>Consejos para maximizar estas herramientas</h2>
            
            <ol>
              <li><strong>Aprende los fundamentos</strong>: Antes de usar frameworks, domina HTML, CSS y JavaScript vanilla</li>
              <li><strong>Configura tu entorno</strong>: Invierte tiempo en configurar tu editor con las extensiones correctas</li>
              <li><strong>Practica con proyectos reales</strong>: La mejor forma de aprender es construyendo proyectos completos</li>
              <li><strong>Mantente actualizado</strong>: El ecosistema web evoluciona rápidamente, sigue blogs y comunidades</li>
              <li><strong>Contribuye a open source</strong>: Es una excelente forma de mejorar tus habilidades y retribuir a la comunidad</li>
            </ol>

            <h2>Construyendo tu stack de desarrollo</h2>
            
            <p>Un stack típico para desarrollo web moderno podría incluir:</p>
            
            <ul>
              <li><strong>Editor</strong>: Visual Studio Code</li>
              <li><strong>Framework frontend</strong>: React, Vue.js o Svelte</li>
              <li><strong>Bundler</strong>: Vite o Webpack</li>
              <li><strong>CSS Framework</strong>: Tailwind CSS o Bootstrap</li>
              <li><strong>Testing</strong>: Jest + Cypress</li>
              <li><strong>Backend</strong>: Node.js + Express o Firebase</li>
              <li><strong>Base de datos</strong>: PostgreSQL (Supabase) o MongoDB</li>
              <li><strong>Hosting</strong>: Netlify o Vercel</li>
            </ul>

            <h2>Conclusión</h2>
            
            <p>El ecosistema de herramientas gratuitas para desarrollo web es increíblemente rico y maduro. Estas herramientas no solo te permiten crear sitios web profesionales sin costo, sino que también son las mismas que utilizan las empresas más grandes del mundo.</p>
            
            <p>La clave está en elegir las herramientas correctas para tu proyecto específico y dedicar tiempo a aprender a usarlas efectivamente. Con este conjunto de herramientas gratuitas, puedes crear prácticamente cualquier tipo de aplicación web moderna.</p>
            
            <p>Recuerda que las herramientas son solo medios para un fin. Lo más importante es entender los conceptos fundamentales del desarrollo web y mantenerse actualizado con las mejores prácticas de la industria.</p>
            
          </div>
          
          <!-- Tags -->
          <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-700">
            <div class="flex flex-wrap gap-2">
              {article.tags.map(tag => (
                <span class="px-3 py-1 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 rounded-full text-sm">
                  #{tag}
                </span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </article>

    <!-- Related Articles -->
    <section class="py-16 bg-gray-50 dark:bg-gray-900">
      <div class="container-wide">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-8 text-center">
            Artículos Relacionados
          </h2>
          
          <div class="grid md:grid-cols-2 gap-8">
            {relatedArticles.map(relatedArticle => (
              <a 
                href={relatedArticle.href}
                class="group block bg-white dark:bg-gray-800 rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 overflow-hidden"
              >
                <div class="p-6">
                  <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                    {relatedArticle.title}
                  </h3>
                  <p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed">
                    {relatedArticle.description}
                  </p>
                  <div class="mt-4 flex items-center text-blue-600 dark:text-blue-400 text-sm font-medium">
                    <span>Leer más</span>
                    <svg class="w-4 h-4 ml-1 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Newsletter Signup -->
    <NewsletterSignup client:load />
  </main>

  <Footer />
</Layout>
