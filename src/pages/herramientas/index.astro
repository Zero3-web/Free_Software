---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout 
  title="Herramientas del Sistema - Software Gratis"
  description="Descarga las mejores herramientas del sistema gratuitas: optimizadores, limpiadores, utilidades de seguridad y más."
>
  <Header />
  <main>
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-green-50 via-white to-blue-50 dark:from-gray-900 dark:via-gray-900 dark:to-gray-800 py-20">
      <div class="container-wide">
        <div class="max-w-4xl mx-auto text-center">
          <h1 class="text-4xl md:text-6xl font-bold text-gray-900 dark:text-white mb-6">
            <span class="text-gradient-animate">Herramientas</span> del Sistema
          </h1>
          <p class="text-xl md:text-2xl text-gray-600 dark:text-gray-300 mb-8">
            Optimiza, limpia y mantén tu sistema en perfecto estado
          </p>
        </div>
      </div>
    </section>

    <!-- Categories Grid -->
    <section class="page-section">
      <div class="container-wide">
        <div class="max-w-6xl mx-auto">
          <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 mb-16">
            <div class="text-center p-6 bg-white dark:bg-gray-800 rounded-xl shadow-lg hover:shadow-xl transition-shadow">
              <div class="w-16 h-16 bg-green-100 dark:bg-green-900 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
              </div>
              <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">Optimizadores</h3>
              <p class="text-gray-600 dark:text-gray-300 text-sm">Acelera tu PC</p>
            </div>

            <div class="text-center p-6 bg-white dark:bg-gray-800 rounded-xl shadow-lg hover:shadow-xl transition-shadow">
              <div class="w-16 h-16 bg-blue-100 dark:bg-blue-900 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                </svg>
              </div>
              <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">Limpiadores</h3>
              <p class="text-gray-600 dark:text-gray-300 text-sm">Libera espacio</p>
            </div>

            <div class="text-center p-6 bg-white dark:bg-gray-800 rounded-xl shadow-lg hover:shadow-xl transition-shadow">
              <div class="w-16 h-16 bg-purple-100 dark:bg-purple-900 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                </svg>
              </div>
              <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">Seguridad</h3>
              <p class="text-gray-600 dark:text-gray-300 text-sm">Protege tu sistema</p>
            </div>

            <div class="text-center p-6 bg-white dark:bg-gray-800 rounded-xl shadow-lg hover:shadow-xl transition-shadow">
              <div class="w-16 h-16 bg-orange-100 dark:bg-orange-900 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
              <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">Utilidades</h3>
              <p class="text-gray-600 dark:text-gray-300 text-sm">Herramientas varias</p>
            </div>
          </div>

          <!-- Featured Tools -->
          <div class="mb-16">
            <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-8 text-center">
              Herramientas Destacadas
            </h2>
            
            <div class="grid md:grid-cols-2 gap-8">
              <!-- CCleaner Alternative -->
              <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg overflow-hidden">
                <div class="h-40 bg-gradient-to-br from-green-400 to-blue-500 flex items-center justify-center">
                  <div class="w-16 h-16 bg-white rounded-xl flex items-center justify-center shadow-lg">
                    <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                    </svg>
                  </div>
                </div>
                <div class="p-6">
                  <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">
                    BleachBit
                  </h3>
                  <p class="text-gray-600 dark:text-gray-300 mb-4">
                    Limpiador de sistema potente y gratuito que libera espacio en disco y protege tu privacidad.
                  </p>
                  <div class="flex items-center justify-between">
                    <span class="text-sm text-green-600 dark:text-green-400 font-medium">Gratuito</span>
                    <button class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors">
                      Descargar
                    </button>
                  </div>
                </div>
              </div>

              <!-- System Optimizer -->
              <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg overflow-hidden">
                <div class="h-40 bg-gradient-to-br from-blue-400 to-purple-500 flex items-center justify-center">
                  <div class="w-16 h-16 bg-white rounded-xl flex items-center justify-center shadow-lg">
                    <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                    </svg>
                  </div>
                </div>
                <div class="p-6">
                  <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">
                    Wise Care 365
                  </h3>
                  <p class="text-gray-600 dark:text-gray-300 mb-4">
                    Suite completa de optimización que mantiene tu PC funcionando como nuevo.
                  </p>
                  <div class="flex items-center justify-between">
                    <span class="text-sm text-blue-600 dark:text-blue-400 font-medium">Freemium</span>
                    <button class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
                      Descargar
                    </button>
                  </div>
                </div>
              </div>

              <!-- Antivirus -->
              <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg overflow-hidden">
                <div class="h-40 bg-gradient-to-br from-purple-400 to-pink-500 flex items-center justify-center">
                  <div class="w-16 h-16 bg-white rounded-xl flex items-center justify-center shadow-lg">
                    <svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                    </svg>
                  </div>
                </div>
                <div class="p-6">
                  <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">
                    Avast Free Antivirus
                  </h3>
                  <p class="text-gray-600 dark:text-gray-300 mb-4">
                    Protección antivirus esencial y gratuita para mantener tu sistema seguro.
                  </p>
                  <div class="flex items-center justify-between">
                    <span class="text-sm text-purple-600 dark:text-purple-400 font-medium">Gratuito</span>
                    <button class="px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition-colors">
                      Descargar
                    </button>
                  </div>
                </div>
              </div>

              <!-- File Manager -->
              <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg overflow-hidden">
                <div class="h-40 bg-gradient-to-br from-orange-400 to-red-500 flex items-center justify-center">
                  <div class="w-16 h-16 bg-white rounded-xl flex items-center justify-center shadow-lg">
                    <svg class="w-8 h-8 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path>
                    </svg>
                  </div>
                </div>
                <div class="p-6">
                  <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">
                    7-Zip
                  </h3>
                  <p class="text-gray-600 dark:text-gray-300 mb-4">
                    Compresor de archivos gratuito con excelente ratio de compresión y soporte múltiples formatos.
                  </p>
                  <div class="flex items-center justify-between">
                    <span class="text-sm text-orange-600 dark:text-orange-400 font-medium">Open Source</span>
                    <button class="px-4 py-2 bg-orange-600 text-white rounded-lg hover:bg-orange-700 transition-colors">
                      Descargar
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Tips Section -->
          <div class="bg-gradient-to-r from-gray-50 to-gray-100 dark:from-gray-800 dark:to-gray-700 rounded-2xl p-8">
            <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-6 text-center">
              💡 Consejos de Mantenimiento
            </h3>
            <div class="grid md:grid-cols-3 gap-6">
              <div class="text-center">
                <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900 rounded-full flex items-center justify-center mx-auto mb-3">
                  <span class="text-2xl">🧹</span>
                </div>
                <h4 class="font-semibold text-gray-900 dark:text-white mb-2">Limpieza Regular</h4>
                <p class="text-sm text-gray-600 dark:text-gray-300">
                  Ejecuta un limpiador de sistema al menos una vez por semana
                </p>
              </div>
              <div class="text-center">
                <div class="w-12 h-12 bg-green-100 dark:bg-green-900 rounded-full flex items-center justify-center mx-auto mb-3">
                  <span class="text-2xl">🛡️</span>
                </div>
                <h4 class="font-semibold text-gray-900 dark:text-white mb-2">Protección Activa</h4>
                <p class="text-sm text-gray-600 dark:text-gray-300">
                  Mantén tu antivirus actualizado y activo en todo momento
                </p>
              </div>
              <div class="text-center">
                <div class="w-12 h-12 bg-purple-100 dark:bg-purple-900 rounded-full flex items-center justify-center mx-auto mb-3">
                  <span class="text-2xl">⚡</span>
                </div>
                <h4 class="font-semibold text-gray-900 dark:text-white mb-2">Optimización</h4>
                <p class="text-sm text-gray-600 dark:text-gray-300">
                  Desfragmenta tu disco duro mensualmente para mejor rendimiento
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
