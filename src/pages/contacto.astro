---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contacto - Software Gratis">
  <Header />
  <main class="min-h-screen bg-[var(--bg-secondary)]">
    <div class="container mx-auto px-4 py-12">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-12">
          <h1 class="text-4xl font-bold text-[var(--text-primary)] mb-4">
            Contáctanos
          </h1>
          <p class="text-xl text-[var(--text-secondary)] max-w-3xl mx-auto">
            ¿Tienes preguntas, sugerencias o necesitas ayuda? Estamos aquí para ayudarte. 
            Escríbenos y te responderemos lo antes posible.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-12">
          <!-- Formulario de Contacto -->
          <div class="bg-[var(--bg-primary)] rounded-xl shadow-lg p-8">
            <h2 class="text-2xl font-semibold text-[var(--text-primary)] mb-6">
              Envíanos un Mensaje
            </h2>
            
            <form class="space-y-6" id="contact-form">
              <div class="grid md:grid-cols-2 gap-4">
                <div>
                  <label for="name" class="block text-sm font-medium text-[var(--text-secondary)] mb-2">
                    Nombre *
                  </label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    class="w-full px-4 py-3 border border-[var(--border-primary)] rounded-lg bg-[var(--bg-secondary)] text-[var(--text-primary)] focus:ring-2 focus:ring-[var(--accent-primary)] focus:border-transparent transition-all"
                    placeholder="Tu nombre completo"
                  />
                </div>
                <div>
                  <label for="email" class="block text-sm font-medium text-[var(--text-secondary)] mb-2">
                    Email *
                  </label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="w-full px-4 py-3 border border-[var(--border-primary)] rounded-lg bg-[var(--bg-secondary)] text-[var(--text-primary)] focus:ring-2 focus:ring-[var(--accent-primary)] focus:border-transparent transition-all"
                    placeholder="tu@email.com"
                  />
                </div>
              </div>

              <div>
                <label for="subject" class="block text-sm font-medium text-[var(--text-secondary)] mb-2">
                  Asunto *
                </label>
                <select
                  id="subject"
                  name="subject"
                  required
                  class="w-full px-4 py-3 border border-[var(--border-primary)] rounded-lg bg-[var(--bg-secondary)] text-[var(--text-primary)] focus:ring-2 focus:ring-[var(--accent-primary)] focus:border-transparent transition-all"
                >
                  <option value="">Selecciona un tema</option>
                  <option value="general">Consulta General</option>
                  <option value="software">Solicitud de Software</option>
                  <option value="bug">Reporte de Error</option>
                  <option value="suggestion">Sugerencia</option>
                  <option value="partnership">Colaboración</option>
                  <option value="other">Otro</option>
                </select>
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-[var(--text-secondary)] mb-2">
                  Mensaje *
                </label>
                <textarea
                  id="message"
                  name="message"
                  rows="6"
                  required
                  class="w-full px-4 py-3 border border-[var(--border-primary)] rounded-lg bg-[var(--bg-secondary)] text-[var(--text-primary)] focus:ring-2 focus:ring-[var(--accent-primary)] focus:border-transparent transition-all resize-none"
                  placeholder="Describe tu consulta o mensaje..."
                ></textarea>
              </div>

              <div class="flex items-center">
                <input
                  type="checkbox"
                  id="privacy"
                  name="privacy"
                  required
                  class="w-4 h-4 text-[var(--accent-primary)] bg-[var(--bg-secondary)] border-[var(--border-primary)] rounded focus:ring-[var(--accent-primary)]"
                />
                <label for="privacy" class="ml-2 text-sm text-[var(--text-secondary)]">
                  Acepto la <a href="/privacidad" class="text-[var(--accent-primary)] hover:underline">Política de Privacidad</a> *
                </label>
              </div>

              <button
                type="submit"
                class="w-full bg-[var(--accent-primary)] text-white py-3 px-6 rounded-lg font-semibold hover:bg-[var(--accent-secondary)] transition-colors focus:ring-2 focus:ring-[var(--accent-primary)] focus:ring-offset-2"
              >
                Enviar Mensaje
              </button>
            </form>
          </div>

          <!-- Información de Contacto -->
          <div class="space-y-8">
            <!-- Información Principal -->
            <div class="bg-[var(--bg-primary)] rounded-xl shadow-lg p-8">
              <h2 class="text-2xl font-semibold text-[var(--text-primary)] mb-6">
                Información de Contacto
              </h2>
              
              <div class="space-y-4">
                <div class="flex items-start space-x-3">
                  <div class="w-10 h-10 bg-[var(--accent-primary)] rounded-lg flex items-center justify-center">
                    <span class="text-white text-lg">📧</span>
                  </div>
                  <div>
                    <h3 class="font-semibold text-[var(--text-primary)]">Email</h3>
                    <p class="text-[var(--text-secondary)]">contacto@softwaregratis.com</p>
                    <p class="text-sm text-[var(--text-muted)]">Respuesta en 24-48 horas</p>
                  </div>
                </div>

                <div class="flex items-start space-x-3">
                  <div class="w-10 h-10 bg-[var(--accent-primary)] rounded-lg flex items-center justify-center">
                    <span class="text-white text-lg">📞</span>
                  </div>
                  <div>
                    <h3 class="font-semibold text-[var(--text-primary)]">Teléfono</h3>
                    <p class="text-[var(--text-secondary)]">+1 (555) 123-4567</p>
                    <p class="text-sm text-[var(--text-muted)]">Lun-Vie 9:00-18:00 EST</p>
                  </div>
                </div>

                <div class="flex items-start space-x-3">
                  <div class="w-10 h-10 bg-[var(--accent-primary)] rounded-lg flex items-center justify-center">
                    <span class="text-white text-lg">📍</span>
                  </div>
                  <div>
                    <h3 class="font-semibold text-[var(--text-primary)]">Dirección</h3>
                    <p class="text-[var(--text-secondary)]">123 Tech Street<br/>Digital City, DC 12345<br/>Estados Unidos</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Redes Sociales -->
            <div class="bg-[var(--bg-primary)] rounded-xl shadow-lg p-8">
              <h2 class="text-2xl font-semibold text-[var(--text-primary)] mb-6">
                Síguenos
              </h2>
              
              <div class="grid grid-cols-2 gap-4">
                <a href="#" class="flex items-center space-x-2 p-3 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition-colors">
                  <span class="text-lg">📘</span>
                  <span class="font-medium">Facebook</span>
                </a>
                
                <a href="#" class="flex items-center space-x-2 p-3 bg-black text-white rounded-lg hover:bg-gray-800 transition-colors">
                  <span class="text-lg">🐦</span>
                  <span class="font-medium">Twitter</span>
                </a>
                
                <a href="#" class="flex items-center space-x-2 p-3 bg-blue-700 text-white rounded-lg hover:bg-blue-800 transition-colors">
                  <span class="text-lg">💼</span>
                  <span class="font-medium">LinkedIn</span>
                </a>
                
                <a href="#" class="flex items-center space-x-2 p-3 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors">
                  <span class="text-lg">📺</span>
                  <span class="font-medium">YouTube</span>
                </a>
              </div>
            </div>

            <!-- FAQ Rápido -->
            <div class="bg-[var(--bg-primary)] rounded-xl shadow-lg p-8">
              <h2 class="text-2xl font-semibold text-[var(--text-primary)] mb-6">
                Preguntas Frecuentes
              </h2>
              
              <div class="space-y-4">
                <div>
                  <h3 class="font-semibold text-[var(--text-primary)] mb-2">¿Todo el software es realmente gratis?</h3>
                  <p class="text-sm text-[var(--text-secondary)]">Sí, solo incluimos software completamente gratuito y legal.</p>
                </div>
                
                <div>
                  <h3 class="font-semibold text-[var(--text-primary)] mb-2">¿Cómo solicito nuevo software?</h3>
                  <p class="text-sm text-[var(--text-secondary)]">Usa el formulario con el asunto "Solicitud de Software".</p>
                </div>
                
                <div>
                  <h3 class="font-semibold text-[var(--text-primary)] mb-2">¿Ofrecen soporte técnico?</h3>
                  <p class="text-sm text-[var(--text-secondary)]">Proporcionamos ayuda con descargas, no soporte del software específico.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  // Manejo del formulario de contacto
  const form = document.getElementById('contact-form');
  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      
      // Aquí normalmente enviarías los datos a un servidor
      // Para demo, solo mostramos un mensaje
      alert('¡Gracias por tu mensaje! Te responderemos pronto.');
      (form as HTMLFormElement).reset();
    });
  }
</script>
